# ─── Server-side provider selection ────────────────────────────────────────
# Every flag defaults to a working keyless option. Flip one at a time.

EARN_PROVIDER=mock                 # mock | lifi     (hybrid-real: live APY, seed fees/risk)
INTENT_FACTORY_PROVIDER=mock       # mock | real     (real is intentionally not implemented)
PRICING_PROVIDER=lifi              # lifi | mock     (open LI.FI Quote API, no key required)

# ─── Funding rail (Revolut integration) ───────────────────────────────────
# simulator         — default; no keys needed; styled Revolut sandbox page we host
# merchant          — real Revolut Merchant sandbox checkout (fiat only)
# merchant-onchain  — real Revolut Merchant + real Sepolia EURC transfer
FUNDING_PROVIDER=simulator

# Required for merchant / merchant-onchain modes. Self-serve sandbox key:
#   1. https://sandbox-business.revolut.com (instant, auto-approved)
#   2. Dashboard → APIs → Merchant API → Generate
REVOLUT_MERCHANT_SECRET_KEY=
REVOLUT_MERCHANT_BASE_URL=https://sandbox-merchant.revolut.com/api
REVOLUT_MERCHANT_API_VERSION=2024-09-01

# Public origin the audience-facing /stage surface is reachable on.
#
# REQUIRED for merchant / merchant-onchain modes because Revolut redirects
# the user's phone here after a successful payment, and Revolut rejects
# localhost redirect URLs. Use an ngrok tunnel for local development:
#
#   npx ngrok http 3000
#
# Then paste the https URL here. Simulator mode does NOT need this — the
# whole flow stays inside our Next app.
PUBLIC_BASE_URL=

# Mirror of PUBLIC_BASE_URL exposed to the browser so the operator's QR
# code targets the real audience-reachable URL rather than localhost.
# Safe to inline — it's just a URL.
NEXT_PUBLIC_PUBLIC_BASE_URL=

# Required only for FUNDING_PROVIDER=merchant-onchain mode.
#   Sepolia ETH faucet:  https://www.alchemy.com/faucets/ethereum-sepolia
#   Sepolia EURC faucet: https://faucet.circle.com/  (Ethereum Sepolia → EURC)
SEPOLIA_SOURCE_PRIVATE_KEY=
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
FUNDING_DEST_WALLET=
DEMO_ONCHAIN_AMOUNT_EURC=0.1

# ─── Simulator timing ─────────────────────────────────────────────────────
# Time between visible milestones when FUNDING_PROVIDER=simulator.
FUNDING_SIM_STEP_MS=2200

# ─── API keys ──────────────────────────────────────────────────────────────
LIFI_API_KEY=                      # Earn API (50 req/min, partner-portal issued). Pricing works keyless.

# ─── Vapi (voice agent) ────────────────────────────────────────────────────
# Client-safe (inlined into the browser bundle). Required to run a real call.
NEXT_PUBLIC_TELEPHONY_PROVIDER=browser  # browser | vapi
NEXT_PUBLIC_VAPI_PUBLIC_KEY=
NEXT_PUBLIC_VAPI_ASSISTANT_ID=
# Display your Vapi-managed phone number on the dashboard so users can dial in.
NEXT_PUBLIC_VAPI_PHONE_NUMBER=

# Server-side shared secret for /api/vapi/webhook. When set, the assistant's
# tool-call server config MUST include header `x-vapi-secret: <this value>`.
VAPI_WEBHOOK_SECRET=

# Outbound calling — "Call me" button on the operator console. Server-side only.
VAPI_PRIVATE_KEY=
VAPI_PHONE_NUMBER_ID=
VAPI_ASSISTANT_ID=
