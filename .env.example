# ─── Server-side provider selection ────────────────────────────────────────
# Every flag defaults to a working mock/keyless option. Flip one at a time.

EARN_PROVIDER=mock                 # mock | lifi   (hybrid-real: live APY, seed fees/risk)
INTENT_FACTORY_PROVIDER=mock       # mock | real   (real is intentionally not implemented)
REVOLUT_PROVIDER=mock              # mock | real   (real is intentionally not implemented — see revolut/real.ts)
PRICING_PROVIDER=lifi              # lifi | mock   (open LI.FI Quote API, no key required)

# ─── API keys ──────────────────────────────────────────────────────────────
LIFI_API_KEY=                      # Earn API (50 req/min, partner-portal issued). Pricing works keyless.
REVOLUT_API_KEY=                   # Not used until a Ramp integration lands.

# ─── Vapi (voice agent) ────────────────────────────────────────────────────
# Client-safe (inlined into the browser bundle). Required to run a real call.
NEXT_PUBLIC_TELEPHONY_PROVIDER=browser  # browser | vapi
NEXT_PUBLIC_VAPI_PUBLIC_KEY=            # dashboard → Public Key
NEXT_PUBLIC_VAPI_ASSISTANT_ID=          # dashboard → Assistant ID (see docs/vapi-assistant-config.md)
# Display your Vapi-managed phone number on the dashboard so users can dial in.
# Formatted as they should tap it (e.g. +1-415-555-1234).
NEXT_PUBLIC_VAPI_PHONE_NUMBER=

# Server-side shared secret for /api/vapi/webhook. When set, the assistant's
# tool-call server config MUST include header `x-vapi-secret: <this value>`.
VAPI_WEBHOOK_SECRET=

# Outbound calling — "Call me" button on the dashboard. Server-side only.
#   Private key: dashboard → Vapi API Keys → Private API Key (NEVER ship to the browser).
#   Phone number id: dashboard → Phone Numbers → click the number → copy its id.
#   Assistant id (optional, falls back to NEXT_PUBLIC_VAPI_ASSISTANT_ID).
VAPI_PRIVATE_KEY=
VAPI_PHONE_NUMBER_ID=
VAPI_ASSISTANT_ID=
